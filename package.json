{
    "name": "whatsapp-rust-bridge-baron",
    "version": "1.0.0",
    "description": "A high-performance utilities for WhatsApp, powered by Rust and WebAssembly.",
    "author": "Baron",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/7ucg/whatsapp-rust-bridge.git"
    },
    "files": [
        "dist/**/*",
        "pkg/**/*"
    ],
    "exports": {
        ".": {
            "require": "./dist/index.js"
        }
    },
    "scripts": {

        "build:wasm": "wasm-pack build --target web --out-dir pkg --no-pack",
        "build:ts": "tsc ts/index.ts --outDir dist --module es2022 --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck",
        "postbuild": "tsc -p tsconfig.json --outDir dist && node -e \"try{require('fs').unlinkSync('dist/macro.d.ts')}catch(e){}\"",
        "build": "npm run build:wasm && npm run build:ts && npm run postbuild"
    },
    "devDependencies": {
        "@mitata/counters": "^0.0.8",
        "@types/bun": "^1.3.14",
        "@types/node": "^22.0.0",
        "audio-decode": "^2.1.3",
        "mitata": "^1.0.34",
        "sharp": "^0.34.5",
        "typescript": "^5.9.3"
    },
    "private": false,
    "dependencies": {}
}
