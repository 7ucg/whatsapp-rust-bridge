# ── Rust build outputs ────────────────────────────────────────────────────────
/target
/native/target
internal/**/target

# ── Lock files ────────────────────────────────────────────────────────────────
Cargo.lock
native/Cargo.lock
package-lock.json
bun.lock

# ── WASM output (wasm-pack) ───────────────────────────────────────────────────
# pkg/ has its own .gitignore (*) — this covers accidental root-level artifacts
*.wasm
*.wat

# ── iai-callgrind benchmark output ───────────────────────────────────────────
target/iai

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
*.tgz
*.tsbuildinfo

# ── Native dist (generated by build-all.ps1) ──────────────────────────────────
/dist-native/

# ── OS & editor ───────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ── Env / secrets ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
